{
  "name": "@labmgm/cli",
  "version": "0.1.0",
  "description": "The `ds` CLI for the MGM Laboratory Design System — scaffold a Next.js 15 app (`ds init`), copy typed components into a project (`ds add`), and manage themes / tokens / icons / health (`ds theme/token/icon/doctor`).",
  "keywords": [
    "cli",
    "ds",
    "labmgm",
    "mgm",
    "design-system",
    "scaffold",
    "shadcn",
    "next.js"
  ],
  "homepage": "https://github.com/MGM-Laboratory/ds-cli#readme",
  "bugs": {
    "url": "https://github.com/MGM-Laboratory/ds-cli/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MGM-Laboratory/ds-cli.git"
  },
  "license": "MIT",
  "author": "MGM Laboratory <design@labmgm.org>",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "ds": "./bin/ds.mjs"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": ["bin", "dist", "templates", "README.md", "LICENSE", "CHANGELOG.md"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rimraf dist",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm clean && pnpm build && changeset publish",
    "prepare": "husky"
  },
  "dependencies": {
    "@clack/prompts": "^0.9.0",
    "commander": "^12.1.0",
    "execa": "^9.5.2",
    "magicast": "^0.3.5",
    "picocolors": "^1.1.1",
    "tinyglobby": "^0.2.10"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.9",
    "@commitlint/cli": "^19.5.0",
    "@commitlint/config-conventional": "^21.0.1",
    "@eslint/js": "^9.18.0",
    "@types/node": "^22.10.5",
    "@typescript-eslint/eslint-plugin": "^8.20.0",
    "@typescript-eslint/parser": "^8.20.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "husky": "^9.1.7",
    "lint-staged": "^15.4.1",
    "prettier": "^3.4.2",
    "rimraf": "^6.0.1",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.4",
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
